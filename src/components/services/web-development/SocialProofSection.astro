---
import type { TrustSignal } from '../../../constants/webDevelopment';

interface Props {
  signals: TrustSignal[];
}

const { signals } = Astro.props;
---

<section class="wd-commitment" aria-labelledby="commitment-heading">
  <div class="wd-commitment__inner">
    <div class="wd-commitment__left">
      <p class="wd-commitment__eyebrow">Our Commitment</p>
      <h2 id="commitment-heading" class="wd-commitment__heading">
        What Every Project Includes
      </h2>
      <p class="wd-commitment__subtext">
        Standards we hold to throughout every engagement — not just on launch day.
      </p>
      <a href="/contact" class="wd-commitment__cta">Book a call</a>
    </div>
    <ol class="wd-commitment__list">
      {signals.map((signal, i) => (
        <li class="wd-commitment__item">
          <span class="wd-commitment__num" aria-hidden="true">0{i + 1}</span>
          <div class="wd-commitment__item-content">
            <h3 class="wd-commitment__item-title">{signal.title}</h3>
            <p class="wd-commitment__item-desc">{signal.description}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .wd-commitment {
    background-color: var(--color-on-background);
    border-top: 4px solid var(--color-on-background);
    padding: var(--spacing-20) var(--spacing-section-x);
  }

  .wd-commitment__inner {
    max-width: var(--max-width-content);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-12);
  }

  /* ---- Left column: statement ---- */
  .wd-commitment__left {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-5);
  }

  .wd-commitment__eyebrow {
    width: fit-content;
    border: 2px solid var(--color-inverse-primary);
    color: var(--color-inverse-primary);
    font-family: var(--font-headline);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: var(--spacing-1) var(--spacing-4);
  }

  .wd-commitment__heading {
    font-family: var(--font-headline);
    font-size: clamp(2rem, 5vw, 3.75rem);
    font-weight: 900;
    line-height: 1.05;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    color: var(--color-inverse-on-surface);
    max-width: 14ch;
  }

  .wd-commitment__subtext {
    font-family: var(--font-body);
    font-size: 1.1rem;
    line-height: 1.7;
    color: color-mix(in srgb, var(--color-inverse-on-surface) 65%, transparent);
    max-width: 36ch;
  }

  .wd-commitment__cta {
    width: fit-content;
    margin-top: var(--spacing-3);
    font-family: var(--font-headline);
    font-weight: 900;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: var(--spacing-4) var(--spacing-8);
    border: 3px solid var(--color-inverse-primary);
    background-color: transparent;
    color: var(--color-inverse-primary);
    box-shadow: var(--shadow-white-sm);
    transition: transform 0.15s, box-shadow 0.15s;
    display: inline-block;
  }

  .wd-commitment__cta:hover {
    transform: translate(4px, 4px);
    box-shadow: none;
  }

  /* ---- Right column: numbered list ---- */
  .wd-commitment__list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .wd-commitment__item {
    display: flex;
    gap: var(--spacing-6);
    padding: var(--spacing-7) 0;
    border-bottom: 1px solid color-mix(in srgb, var(--color-inverse-on-surface) 18%, transparent);
  }

  .wd-commitment__item:first-child {
    border-top: 1px solid color-mix(in srgb, var(--color-inverse-on-surface) 18%, transparent);
  }

  .wd-commitment__num {
    font-family: var(--font-headline);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-inverse-primary);
    flex-shrink: 0;
    padding-top: var(--spacing-1);
    letter-spacing: 0.05em;
  }

  .wd-commitment__item-content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  .wd-commitment__item-title {
    font-family: var(--font-headline);
    font-size: 1.1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-inverse-on-surface);
  }

  .wd-commitment__item-desc {
    font-family: var(--font-body);
    line-height: 1.65;
    color: color-mix(in srgb, var(--color-inverse-on-surface) 65%, transparent);
  }

  @media (min-width: 1024px) {
    .wd-commitment__inner {
      grid-template-columns: 1fr 1.4fr;
      gap: var(--spacing-24);
      align-items: start;
    }
  }
</style>
