---
import type { FinalCta } from '../../../constants/webDevelopment';

interface Props {
  cta: FinalCta;
}

const { cta } = Astro.props;
---

<section class="wd-section wd-final-cta" aria-labelledby="final-cta-heading">
  <div class="wd-final-cta__inner brutalist-grid">
    <div class="wd-final-cta__content">
      <p class="wd-final-cta__eyebrow">Start Your Project</p>
      <h2 id="final-cta-heading" class="wd-final-cta__title">{cta.title}</h2>
      <p class="wd-final-cta__description">{cta.description}</p>
    </div>

    <div class="wd-final-cta__actions">
      <a href={cta.primaryHref} class="wd-final-cta__btn wd-final-cta__btn--primary">{cta.primaryLabel}</a>
      <a href={cta.secondaryHref} class="wd-final-cta__btn wd-final-cta__btn--secondary">{cta.secondaryLabel}</a>
    </div>
  </div>
</section>

<style>
  .wd-section {
    padding: var(--spacing-20) var(--spacing-section-x);
    border-top: var(--spacing-1) solid var(--color-on-background);
  }

  .wd-final-cta {
    background-color: var(--color-surface-container-lowest);
    border-bottom: var(--spacing-1) solid var(--color-on-background);
  }

  .wd-final-cta__inner {
    max-width: var(--max-width-content);
    margin: 0 auto;
    border: var(--spacing-1) solid var(--color-on-background);
    box-shadow: var(--shadow-lg);
    background-color: color-mix(in srgb, var(--color-primary-fixed) 65%, var(--color-surface) 35%);
    padding: var(--spacing-12);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-10);
  }

  .wd-final-cta__content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
    max-width: 65ch;
  }

  .wd-final-cta__eyebrow {
    width: fit-content;
    border: calc(var(--spacing-1) / 2) solid var(--color-on-background);
    background-color: var(--color-on-background);
    color: var(--color-on-primary);
    font-family: var(--font-headline);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: var(--spacing-1) var(--spacing-4);
  }

  .wd-final-cta__title {
    font-family: var(--font-headline);
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 900;
    line-height: 1.05;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    max-width: 16ch;
  }

  .wd-final-cta__description {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.25rem);
    line-height: 1.7;
    color: var(--color-on-surface-variant);
  }

  .wd-final-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-5);
  }

  .wd-final-cta__btn {
    font-family: var(--font-headline);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 1rem;
    padding: var(--spacing-5) var(--spacing-8);
    border: var(--spacing-1) solid var(--color-on-background);
    box-shadow: var(--shadow-md);
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .wd-final-cta__btn:hover {
    transform: translate(var(--spacing-1), var(--spacing-1));
    box-shadow: var(--shadow-sm);
  }

  .wd-final-cta__btn--primary {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
  }

  .wd-final-cta__btn--secondary {
    background-color: var(--color-surface);
    color: var(--color-on-background);
  }
</style>
