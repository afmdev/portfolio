---
import type { TechStackItem } from '../../../constants/webDevelopment';

interface Props {
  stack: TechStackItem[];
}

const { stack } = Astro.props;

const logoMonograms: Record<string, string> = {
  React: 'R',
  'Next.js': 'N',
  Astro: 'A',
  TypeScript: 'TS',
  SolidJS: 'S',
};
---

<section class="wd-section wd-stack" aria-labelledby="tech-stack-heading">
  <div class="wd-section__intro">
    <p class="wd-section__eyebrow">Technology Stack</p>
    <h2 id="tech-stack-heading" class="wd-section__title">Framework Expertise for High-Performance Websites and Apps</h2>
    <p class="wd-section__description">
      We choose technology based on product requirements, team capacity, and long-term maintainability. These are the core stacks we use to ship reliable outcomes.
    </p>
  </div>

  <div class="wd-stack__grid" role="list">
    {stack.map((item) => (
      <article class="wd-stack__card" role="listitem">
        <div class="wd-stack__logo" style={`background-color: ${item.accent};`} aria-hidden="true">{logoMonograms[item.name] ?? item.name.slice(0, 1)}</div>
        <div class="wd-stack__content">
          <h3 class="wd-stack__title">{item.name}</h3>
          <p class="wd-stack__role">{item.role}</p>
          <p class="wd-stack__description">{item.description}</p>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .wd-section {
    padding: var(--spacing-20) var(--spacing-section-x);
    border-top: var(--spacing-1) solid var(--color-on-background);
  }

  .wd-section__intro {
    max-width: var(--max-width-content);
    margin: 0 auto var(--spacing-12);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
  }

  .wd-section__eyebrow {
    width: fit-content;
    border: calc(var(--spacing-1) / 2) solid var(--color-on-background);
    background-color: var(--color-secondary-fixed);
    color: var(--color-on-secondary-fixed);
    font-family: var(--font-headline);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: var(--spacing-1) var(--spacing-4);
  }

  .wd-section__title {
    font-family: var(--font-headline);
    font-size: clamp(2rem, 5vw, 3.75rem);
    font-weight: 900;
    line-height: 1.05;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    max-width: 18ch;
  }

  .wd-section__description {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.7;
    color: var(--color-on-surface-variant);
    max-width: 68ch;
  }

  .wd-stack {
    background-color: var(--color-surface-container-lowest);
  }

  .wd-stack__grid {
    max-width: var(--max-width-content);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-7);
  }

  .wd-stack__card {
    border: var(--spacing-1) solid var(--color-on-background);
    box-shadow: var(--shadow-md);
    background-color: var(--color-surface);
    padding: var(--spacing-8);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-6);
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .wd-stack__card:hover {
    transform: translate(var(--spacing-1), var(--spacing-1));
    box-shadow: var(--shadow-sm);
  }

  .wd-stack__logo {
    width: var(--spacing-16);
    min-width: var(--spacing-16);
    height: var(--spacing-16);
    border: calc(var(--spacing-1) / 2) solid var(--color-on-background);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-headline);
    font-size: 1.1rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .wd-stack__content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
  }

  .wd-stack__title {
    font-family: var(--font-headline);
    font-size: 1.5rem;
    font-weight: 900;
    text-transform: uppercase;
    line-height: 1.2;
  }

  .wd-stack__role {
    font-family: var(--font-headline);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-secondary);
  }

  .wd-stack__description {
    font-family: var(--font-body);
    line-height: 1.65;
    color: var(--color-on-surface-variant);
  }

  @media (min-width: 768px) {
    .wd-stack__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .wd-stack__card {
      flex-direction: row;
      align-items: flex-start;
    }
  }
</style>
