---
import type { ServiceOffer } from '../../../constants/webDevelopment';

interface Props {
  services: ServiceOffer[];
}

const { services } = Astro.props;
---

<section class="wd-section wd-services" aria-labelledby="services-offered-heading">
  <div class="wd-section__intro">
    <p class="wd-section__eyebrow">What We Build</p>
    <h2 id="services-offered-heading" class="wd-section__title">Capabilities Across React, Next.js, Astro, TypeScript, and SolidJS</h2>
    <p class="wd-section__description">
      Each engagement is scoped around business outcomes and technical fit. Select a focused service or combine them into a complete delivery stream.
    </p>
  </div>

  <div class="wd-services__grid">
    {services.map((service) => (
      <article class="wd-services__card">
        <p class="wd-services__subtitle">{service.subtitle}</p>
        <h3 class="wd-services__title">{service.title}</h3>
        <p class="wd-services__summary">{service.summary}</p>
        <ul class="wd-services__list">
          {service.deliverables.map((deliverable) => (
            <li>{deliverable}</li>
          ))}
        </ul>
      </article>
    ))}
  </div>
</section>

<style>
  .wd-section {
    padding: var(--spacing-20) var(--spacing-section-x);
    border-top: var(--spacing-1) solid var(--color-on-background);
  }

  .wd-section__intro {
    max-width: var(--max-width-content);
    margin: 0 auto var(--spacing-12);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
  }

  .wd-section__eyebrow {
    width: fit-content;
    border: calc(var(--spacing-1) / 2) solid var(--color-on-background);
    background-color: var(--color-tertiary-fixed);
    color: var(--color-on-tertiary-fixed);
    font-family: var(--font-headline);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: var(--spacing-1) var(--spacing-4);
  }

  .wd-section__title {
    font-family: var(--font-headline);
    font-size: clamp(2rem, 5vw, 3.75rem);
    font-weight: 900;
    line-height: 1.05;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    max-width: 20ch;
  }

  .wd-section__description {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.7;
    color: var(--color-on-surface-variant);
    max-width: 68ch;
  }

  .wd-services {
    background-color: var(--color-surface-container-low);
  }

  .wd-services__grid {
    max-width: var(--max-width-content);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-8);
  }

  .wd-services__card {
    border: var(--spacing-1) solid var(--color-on-background);
    background-color: var(--color-surface-container-lowest);
    box-shadow: var(--shadow-md);
    padding: var(--spacing-9);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .wd-services__card:hover {
    transform: translate(var(--spacing-1), var(--spacing-1));
    box-shadow: var(--shadow-sm);
  }

  .wd-services__subtitle {
    font-family: var(--font-headline);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-secondary);
    font-size: 0.75rem;
    font-weight: 700;
  }

  .wd-services__title {
    font-family: var(--font-headline);
    font-size: clamp(1.3rem, 3vw, 1.8rem);
    font-weight: 900;
    text-transform: uppercase;
    line-height: 1.2;
  }

  .wd-services__summary {
    font-family: var(--font-body);
    color: var(--color-on-surface-variant);
    line-height: 1.65;
  }

  .wd-services__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
    margin-top: var(--spacing-2);
  }

  .wd-services__list li {
    font-family: var(--font-body);
    border-left: var(--spacing-1) solid var(--color-primary);
    padding-left: var(--spacing-3);
    line-height: 1.6;
  }

  @media (min-width: 768px) {
    .wd-services__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
