---
// Footer
---

<footer class="site-footer">
  <div class="footer-container">
    <div class="footer-col footer-brand">
      <div class="footer-logo">AFM.BERLIN</div>
      <p class="footer-desc">
        A design agency dedicated to the honest,<br />
        structural, and unapologetically brutalist<br />
        digital landscape.
      </p>
      <div class="footer-social">
        <a class="footer-social-btn" href="#" aria-label="Instagram">IG</a>
        <a class="footer-social-btn" href="#" aria-label="LinkedIn">LI</a>
        <a class="footer-social-btn" href="#" aria-label="Are.na">AR</a>
      </div>
    </div>

    <div class="footer-col footer-nav">
      <p class="footer-col-heading footer-col-heading--nav">NAVIGATION</p>
      <a class="footer-link" href="#">WORK</a>
      <a class="footer-link" href="/services">SERVICES</a>
      <a class="footer-link footer-link--muted" href="/blog">BLOG</a>
      <a class="footer-link" href="#">ABOUT</a>
      <a class="footer-link" href="/contact">CONTACT</a>
    </div>

    <div class="footer-col footer-network">
      <p class="footer-col-heading footer-col-heading--net">NETWORK</p>
      <a class="footer-link" href="#">INSTAGRAM</a>
      <a class="footer-link" href="#">LINKEDIN</a>
      <a class="footer-link" href="#">ARE.NA</a>
      <a class="footer-link" href="#">SAVE</a>
    </div>
  </div>

  <div class="footer-bottom">
    <p class="footer-copyright">
      &copy; 2024 AFM.DEV BUILT FOR THE ARCHITECTURAL CURATOR.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    width: 100%;
    background-color: #1a1a2e;
    border-top: 4px solid #1a1a2e;
    color: #ffffff;
    padding-top: 68px;
    padding-left: 32px;
    padding-right: 32px;
    display: flex;
    flex-direction: column;
    gap: 80px;
  }

  .footer-container {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 48px;
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .footer-container {
      grid-template-columns: 1fr 1fr;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .footer-container {
      grid-template-columns: 1fr;
    }

    .site-footer {
      padding-left: 24px;
      padding-right: 24px;
    }
  }

  /* Brand column */
  .footer-col {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
  }

  .footer-brand {
    gap: 32px;
  }

  .footer-logo {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 36px;
    line-height: 40px;
    color: #ffffff;
  }

  .footer-desc {
    font-family: 'Manrope', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 24px;
    color: rgba(255, 255, 255, 0.6);
    max-width: 320px;
    margin: 0;
  }

  .footer-social {
    display: flex;
    gap: 16px;
  }

  .footer-social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background-color: #ffffff;
    border: 2px solid #ffffff;
    color: #1a1a2e;
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 16px;
    line-height: 24px;
    text-decoration: none;
    transition: background-color 0.15s, color 0.15s;
  }

  .footer-social-btn:hover {
    background-color: #1a1a2e;
    color: #ffffff;
  }

  /* Columns */
  .footer-col-heading {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 24px;
    line-height: 32px;
    text-transform: uppercase;
    margin: 0 0 16px 0;
  }

  .footer-col-heading--nav {
    color: #e8deff;
  }

  .footer-col-heading--net {
    color: #ffdbcd;
  }

  .footer-link {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 14px;
    line-height: 20px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-link:hover {
    color: #ffffff;
  }

  .footer-link--muted {
    color: #605586;
  }

  .footer-link--muted:hover {
    color: #e8deff;
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    padding-top: 33px;
    padding-bottom: 33px;
    display: flex;
    justify-content: center;
  }

  .footer-copyright {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 12px;
    line-height: 16px;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: rgba(255, 255, 255, 0.4);
    text-align: center;
    margin: 0;
  }
</style>
