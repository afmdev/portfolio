---
const navLinks = [
  { href: '/',         label: 'HOME'     },
  { href: '/services', label: 'SERVICES' },
  { href: '/palette',  label: 'PALETTE'  },
  { href: '/tools',    label: 'TOOLS'    },
  { href: '/blog',     label: 'BLOG'     },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <nav class="nav-container" aria-label="Primary navigation">
    <a class="nav-logo" href="/">AFM.DEV</a>

    <div class="nav-links" id="nav-links">
      {navLinks.map(({ href, label }) => (
        <a
          class={`nav-link${currentPath === href ? ' nav-link--active' : ''}`}
          href={href}
          aria-current={currentPath === href ? 'page' : undefined}
        >
          {label}
        </a>
      ))}
    </div>

    <div class="nav-actions">
      <button class="nav-icon-btn" type="button" aria-label="Toggle theme">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="11" cy="11" r="4" stroke="#191c1c" stroke-width="1.5"/>
          <line x1="11" y1="1" x2="11" y2="3" stroke="#191c1c" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="11" y1="19" x2="11" y2="21" stroke="#191c1c" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="1" y1="11" x2="3" y2="11" stroke="#191c1c" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="19" y1="11" x2="21" y2="11" stroke="#191c1c" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="3.93" y1="3.93" x2="5.34" y2="5.34" stroke="#191c1c" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="16.66" y1="16.66" x2="18.07" y2="18.07" stroke="#191c1c" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="18.07" y1="3.93" x2="16.66" y2="5.34" stroke="#191c1c" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="5.34" y1="16.66" x2="3.93" y2="18.07" stroke="#191c1c" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
      <a href="/contact" class="nav-cta">HIRE ME</a>
      <button
        class="nav-hamburger"
        id="hamburger"
        type="button"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <div class="nav-mobile" id="mobile-menu" role="navigation" aria-label="Mobile navigation">
    {navLinks.map(({ href, label }) => (
      <a
        class={`nav-link${currentPath === href ? ' nav-link--active' : ''}`}
        href={href}
        aria-current={currentPath === href ? 'page' : undefined}
      >
        {label}
      </a>
    ))}
  </div>
</header>

<style>
  .site-header {
    width: 100%;
    border-bottom: 4px solid #191c1c;
    background-color: #f8f9f9;
    box-shadow: 4px 4px 0 0 #191c1c;
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    height: 80px;
    padding: 0 2rem;
    max-width: 1280px;
    margin: 0 auto;
  }

  .nav-logo {
    font-size: 1.5rem;
    font-weight: 900;
    letter-spacing: -0.05em;
    color: #191c1c;
    font-family: var(--font-headline);
    text-transform: uppercase;
    flex-shrink: 0;
    text-decoration: none;
  }

  .nav-links {
    display: none;
    gap: 1.5rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .nav-links {
      display: flex;
    }
  }

  .nav-link {
    font-family: var(--font-headline);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: -0.05em;
    font-size: 1rem;
    color: #191c1c;
    padding: 0 0.5rem;
    transition: background-color 0.075s, color 0.075s;
    line-height: 1.5rem;
    white-space: nowrap;
    text-decoration: none;
  }

  .nav-link--active {
    background-color: #3f6355;
    color: #ffffff;
  }

  .nav-link:hover:not(.nav-link--active) {
    background-color: #191c1c;
    color: #ffffff;
  }

  .nav-link:focus-visible {
    outline: 3px solid #3f6355;
    outline-offset: 2px;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  .nav-icon-btn {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    line-height: 0;
  }

  @media (min-width: 768px) {
    .nav-icon-btn {
      display: flex;
      align-items: center;
      justify-content: center;
    }
  }

  .nav-icon-btn:focus-visible {
    outline: 3px solid #3f6355;
    outline-offset: 2px;
  }

  .nav-cta {
    display: none;
    background-color: #3f6355;
    color: #ffffff;
    font-family: var(--font-headline);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: -0.05em;
    text-transform: uppercase;
    padding: 0.625rem 1.625rem;
    border: 2px solid #191c1c;
    box-shadow: 4px 4px 0 0 #191c1c;
    cursor: pointer;
    transition: transform 0.075s, box-shadow 0.075s;
    white-space: nowrap;
    text-decoration: none;
  }

  @media (min-width: 768px) {
    .nav-cta {
      display: block;
    }
  }

  .nav-cta:hover {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 0 #191c1c;
  }

  .nav-cta:active {
    transform: translate(4px, 4px);
    box-shadow: none;
  }

  .nav-cta:focus-visible {
    outline: 3px solid #191c1c;
    outline-offset: 3px;
  }

  /* Hamburger */
  .nav-hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  @media (min-width: 768px) {
    .nav-hamburger {
      display: none;
    }
  }

  .nav-hamburger:focus-visible {
    outline: 3px solid #3f6355;
    outline-offset: 2px;
  }

  .nav-hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background-color: #191c1c;
    transition: transform 0.2s, opacity 0.2s;
  }

  /* Mobile menu */
  .nav-mobile {
    display: none;
    flex-direction: column;
    padding: 1rem 2rem;
    gap: 0.75rem;
    border-top: 2px solid #191c1c;
  }

  .nav-mobile.is-open {
    display: flex;
  }

  @media (min-width: 768px) {
    .nav-mobile {
      display: none !important;
    }
  }
</style>

<script>
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobile-menu');

  hamburger?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('is-open');
    hamburger.setAttribute('aria-expanded', String(isOpen));
  });
</script>
