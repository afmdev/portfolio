---
import Layout from '../layouts/Layout.astro';
import '../styles/pages/index.css';
---

<Layout
  title="AFM.DEV | WEBDESIGN IN BERLIN"
  description="Freelance Design & Development for Modern Creators. Berlin-based web design studio."
>
  <!-- ── Hero ──────────────────────────────────────────────── -->
  <section class="hero brutalist-grid">
    <div class="hero__content">
      <h1 class="hero__title">WEBDESIGN<br />IN BERLIN</h1>
      <p class="hero__subtitle">
        Freelance Design &amp; Development for Modern Creators.
      </p>
      <div class="hero__actions">
        <button class="hero__btn hero__btn--primary">START A PROJECT</button>
        <button class="hero__btn hero__btn--secondary">VIEW WORK</button>
      </div>
    </div>

    <div class="hero__image">
      <div class="hero__image-inner">
        <img
          alt="Brutalist concrete building in Berlin with sharp geometric shadows"
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuDAh_47G1TJFASTBGt9VRP2AJHBXxF7G0iAz0egJy_jlkvxG2s7zTkenxqJ4Lvky8ELHVNWfl1XndhsrJREj5FEXKTWB01cX6thUVq7tl_xBUz6iA3tR3wbrQTvvY-ZG2fqIE57YcItV8aJmgEtAbjl1Z75eqZ43Qb3gL_StMNGB78ZSA8ltp5lJNa6JKXvf-9NlKZzN6uxTJJh5DfrB6OachjnCIJeEws2CnhNnoF8Nk8fZMUreOOeqXFbgjrCkBOr_CAr9kFY18e_"
        />
      </div>
    </div>
  </section>

  <!-- ── Marquee ───────────────────────────────────────────── -->
  <section class="marquee-section">
    <div class="marquee-section__container">
      <div class="marquee-section__track">
        <span class="marquee-section__word">STRATEGY</span>
        <span class="marquee-section__divider"></span>
        <span class="marquee-section__word">DEVELOPMENT</span>
        <span class="marquee-section__divider"></span>
        <span class="marquee-section__word">SEO</span>
        <span class="marquee-section__divider"></span>
        <span class="marquee-section__word">DESIGN</span>
        <span class="marquee-section__divider"></span>
        <!-- Duplicate for seamless loop -->
        <span class="marquee-section__word">STRATEGY</span>
        <span class="marquee-section__divider"></span>
        <span class="marquee-section__word">DEVELOPMENT</span>
        <span class="marquee-section__divider"></span>
        <span class="marquee-section__word">SEO</span>
        <span class="marquee-section__divider"></span>
        <span class="marquee-section__word">DESIGN</span>
        <span class="marquee-section__divider"></span>
      </div>
    </div>
  </section>

  <!-- ── Value Prop ────────────────────────────────────────── -->
  <section class="value-prop">
    <div class="value-prop__card value-prop__card--left">
      <h2 class="value-prop__title">OUR PHILOSOPHY</h2>
      <p class="value-prop__text">
        We believe in the raw honesty of structure. Design is not just decoration;
        it is the skeleton upon which your brand lives. We strip away the
        unnecessary to reveal the core of your digital identity.
      </p>
    </div>
    <div class="value-prop__card value-prop__card--right">
      <h2 class="value-prop__title">DIGITAL PRECISION</h2>
      <p class="value-prop__text">
        Every pixel is an architectural decision. We craft digital spaces with the
        same rigor as Berlin's most iconic monoliths. High-performance development
        meets unapologetic visual curation.
      </p>
    </div>
  </section>

  <!-- ── Services ─────────────────────────────────────────────── -->
  <section class="services">
    <div class="services__heading-area">
      <h2 class="services__title">ARCHITECTING<br/>DIGITAL<br/>EXPERIENCES</h2>
      <p class="services__subtitle">Botanical brutality meets industrial precision. We build robust systems for the modern web with an uncompromising aesthetic.</p>
    </div>

    <div class="services__grid">
      <article class="service-card">
        <div class="service-card__icon service-card__icon--1">
          <img src="https://www.figma.com/api/mcp/asset/913363c3-62e7-4317-85f8-ed617ec51de5" alt="" />
        </div>
        <div class="service-card__body">
          <h3 class="service-card__title">Web Development</h3>
          <p class="service-card__desc">Hard-coded excellence using modern frameworks. Scalable, secure, and structurally sound infrastructure.</p>
        </div>
        <a href="/services/web-development" class="service-card__link">LEARN MORE →</a>
      </article>

      <article class="service-card">
        <div class="service-card__icon service-card__icon--2">
          <img src="https://www.figma.com/api/mcp/asset/f0521e04-9a14-48c9-b7f8-3fa713bed22a" alt="" />
        </div>
        <div class="service-card__body">
          <h3 class="service-card__title">UI/UX Design</h3>
          <p class="service-card__desc">Mathematical layouts and botanical color systems. Interfaces that feel like a digital greenhouse.</p>
        </div>
        <a href="/services/ui-ux-design" class="service-card__link">LEARN MORE →</a>
      </article>

      <article class="service-card">
        <div class="service-card__icon service-card__icon--3">
          <img src="https://www.figma.com/api/mcp/asset/c6ea64fb-35f3-4973-93fe-c6487b931325" alt="" />
        </div>
        <div class="service-card__body">
          <h3 class="service-card__title">SEO Optimization</h3>
          <p class="service-card__desc">Visibility as a structural requirement. We optimize for search algorithms and human intent.</p>
        </div>
        <a href="/services/seo-optimization" class="service-card__link">LEARN MORE →</a>
      </article>

      <article class="service-card">
        <div class="service-card__icon service-card__icon--4">
          <img src="https://www.figma.com/api/mcp/asset/5cf01c57-4626-4af8-b7b4-8e5423d00ff7" alt="" />
        </div>
        <div class="service-card__body">
          <h3 class="service-card__title">Website Audit</h3>
          <p class="service-card__desc">Rigorous technical inspection. We identify structural weaknesses and performance bottlenecks.</p>
        </div>
        <a href="/services" class="service-card__link">LEARN MORE →</a>
      </article>

      <article class="service-card">
        <div class="service-card__icon service-card__icon--5">
          <img src="https://www.figma.com/api/mcp/asset/ba043164-ce2d-41e9-8c93-5b9f57267fcd" alt="" />
        </div>
        <div class="service-card__body">
          <h3 class="service-card__title">Performance Optimization</h3>
          <p class="service-card__desc">Lightning-fast load times. We trim the fat and prioritize vital rendering paths.</p>
        </div>
        <a href="/services" class="service-card__link">LEARN MORE →</a>
      </article>

      <article class="service-card">
        <div class="service-card__icon service-card__icon--6">
          <img src="https://www.figma.com/api/mcp/asset/78cc90fc-70e3-484e-9eec-e8c767b9a44a" alt="" />
        </div>
        <div class="service-card__body">
          <h3 class="service-card__title">Consulting</h3>
          <p class="service-card__desc">Strategic guidance for digital growth. Architectural advice for your next big product launch.</p>
        </div>
        <a href="/services" class="service-card__link">LEARN MORE →</a>
      </article>
    </div>

    <div class="services__cta">
      <div class="services__cta-content">
        <h3 class="services__cta-title">READY TO START BUILDING?</h3>
        <p class="services__cta-text">Every project begins with a blueprint. Let's discuss your architectural vision and bring it to life with precision.</p>
      </div>
      <button class="services__cta-btn">WE ARE READY</button>
    </div>
  </section>

  <!-- ── Blog Articles ────────────────────────────────────────── -->
  <section class="blog-articles">
    <div class="blog-articles__inner">
      <span class="blog-articles__label">BLOG</span>
      <h2 class="blog-articles__title">SOME BORING ARTICLES</h2>

      <div class="blog-articles__grid">

        <article class="article-card">
          <div class="article-card__image-wrap">
            <img class="article-card__image" src="https://www.figma.com/api/mcp/asset/ab0ce6bd-196e-426c-9ef5-8b11c3f523f2" alt="Retro-Tech article hero" />
            <span class="article-card__badge article-card__badge--purple">TECH</span>
          </div>
          <div class="article-card__body">
            <p class="article-card__date">Oct 14, 2024</p>
            <h3 class="article-card__title">RETRO-TECH: WHY ANALOG MATTERS IN DIGITAL</h3>
            <a class="article-card__link" href="#">READ ENTRY</a>
          </div>
        </article>

        <article class="article-card">
          <div class="article-card__image-wrap">
            <img class="article-card__image" src="https://www.figma.com/api/mcp/asset/ae674d3f-a789-483b-8065-ae6a9ab0d652" alt="Web Dev article hero" />
            <span class="article-card__badge article-card__badge--mint">WEB DEV</span>
          </div>
          <div class="article-card__body">
            <p class="article-card__date">Oct 12, 2024</p>
            <h3 class="article-card__title">OPTIMIZING FOR THE SPEED OF LIGHT</h3>
            <a class="article-card__link" href="#">READ ENTRY</a>
          </div>
        </article>

        <article class="article-card">
          <div class="article-card__image-wrap">
            <img class="article-card__image" src="https://www.figma.com/api/mcp/asset/a88b7175-8b75-427f-80f0-24bfbc016299" alt="SEO article hero" />
            <span class="article-card__badge article-card__badge--purple">SEO</span>
          </div>
          <div class="article-card__body">
            <p class="article-card__date">Oct 09, 2024</p>
            <h3 class="article-card__title">ALGORITHMIC POETRY AND SEARCH RANKINGS</h3>
            <a class="article-card__link" href="#">READ ENTRY</a>
          </div>
        </article>

        <article class="article-card">
          <div class="article-card__image-wrap">
            <img class="article-card__image" src="https://www.figma.com/api/mcp/asset/f8069dfb-2341-4e41-82e8-e6613505f0ae" alt="Design article hero" />
            <span class="article-card__badge article-card__badge--mint">DESIGN</span>
          </div>
          <div class="article-card__body">
            <p class="article-card__date">Oct 05, 2024</p>
            <h3 class="article-card__title">STRUCTURAL INTEGRITY IN UI LAYOUTS</h3>
            <a class="article-card__link" href="#">READ ENTRY</a>
          </div>
        </article>

        <article class="article-card">
          <div class="article-card__image-wrap">
            <img class="article-card__image" src="https://www.figma.com/api/mcp/asset/ed59985c-9716-439a-8aab-82df6d89d441" alt="Tech article hero" />
            <span class="article-card__badge article-card__badge--purple">TECH</span>
          </div>
          <div class="article-card__body">
            <p class="article-card__date">Sep 28, 2024</p>
            <h3 class="article-card__title">HARDWARE AS A MEDIUM FOR CREATIVITY</h3>
            <a class="article-card__link" href="#">READ ENTRY</a>
          </div>
        </article>

        <article class="article-card">
          <div class="article-card__image-wrap">
            <img class="article-card__image" src="https://www.figma.com/api/mcp/asset/bea24cc3-ae28-42cd-ae8a-0be0c9f32ee5" alt="Strategy article hero" />
            <span class="article-card__badge article-card__badge--mint">STRATEGY</span>
          </div>
          <div class="article-card__body">
            <p class="article-card__date">Sep 22, 2024</p>
            <h3 class="article-card__title">THE GEOMETRY OF CONSUMER ATTENTION</h3>
            <a class="article-card__link" href="#">READ ENTRY</a>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- ── Testimonials ──────────────────────────────────────── -->
  <section class="testimonials">
    <h3 class="testimonials__title">VOICES OF THE CURATED</h3>

    <div class="testimonials__grid">
      <div class="testimonial-card testimonial-card--1">
        <p class="testimonial-card__quote">
          "AFM.DEV didn't just build a website; they built a fortress for my
          brand. The aesthetic is raw, powerful, and unique."
        </p>
        <div class="testimonial-card__footer">
          <div class="testimonial-card__avatar">
            <img
              alt="Marcus Vogel"
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuBbUGmzhXtYcE_csR_E64WOd3rkWcxZAsvg2IuOXy9OH9C138msAvGzoaCr0lnm_aHxoLRjjFmHvGrWNGSsgVAn2uqAewEYA-ePcX7_MvZM8jM0I8RYqw9wujmV4BXba1VdhGZGAxgKFNoUPmLAq9hknWeuivGhY3I-sx7Kht6HrIz1vPO8tw3XeR5J5sDi6pohb-Xzvke9eYncAtBFMWVA6VyZm5UvJKE0tujw3ewFBPzBQRs-fL2r5Yj5OikiO1x6hR7ICHHzFZpP"
            />
          </div>
          <div>
            <p class="testimonial-card__name">MARCUS VOGEL</p>
            <p class="testimonial-card__role">Founder, Neo Gallery</p>
          </div>
        </div>
      </div>

      <div class="testimonial-card testimonial-card--2">
        <p class="testimonial-card__quote">
          "The level of digital precision is unmatched. Our conversion rates
          tripled because the design commands respect immediately."
        </p>
        <div class="testimonial-card__footer">
          <div class="testimonial-card__avatar">
            <img
              alt="Elena Rossi"
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuDpHhTs2YXrZuMryPxJNEyekNq_j4B_3gKQ0s6c9vvNc-bhKcHCYG7k8XN8zNsblRXVKuaqWGLANWjDCxPLswvsBGJd4HErlmpMuwd8Yo215SMy3O0OFAXIdyT2_0s8-NlCcnJWUHGgtn0DtSDysNnK9E7bTJss2gmJ9wPh5ImOa7WppD7pz_IZNPPIVV37QnNEhqUUZc2FvUbeyg-Yn--zZGBOA5JsSWzuJ-R88i10hYHiYktKUpaC4TdSd8A4RMSqLtY7ljTtHVzu"
            />
          </div>
          <div>
            <p class="testimonial-card__name">ELENA ROSSI</p>
            <p class="testimonial-card__role">Tech Lead, Flow-State</p>
          </div>
        </div>
      </div>

      <div class="testimonial-card testimonial-card--3">
        <p class="testimonial-card__quote">
          "Berlin brutalism at its finest. If you want to stand out from the sea
          of soft-rounded SaaS designs, this is the place."
        </p>
        <div class="testimonial-card__footer">
          <div class="testimonial-card__avatar">
            <img
              alt="Jakob Schmidt"
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuB219GJAnEjcC3lCqolYEbI6YiPAVNtOAe7oKf30Xofy3KrJy-pQBAQZo09FypuT2TE5xQI1dci1Jcw_973UzdvC37Cgs9EgvxJLem3mQmJ2-09sunWaJgLCWQddQYfQ4itHfiREy2-AxJI4lgsh8uEKKgPYPMkjRK1WJdL0Zv7R5tXav-INd4bGRu55JTwmoq_h8N90ILfPMZGDUYzfeSNalcLLHezTPvZFvmypH9cYcgvmCXIBQd6-odrZSjuP1nDLILRLeCx2Ubw"
            />
          </div>
          <div>
            <p class="testimonial-card__name">JAKOB SCHMIDT</p>
            <p class="testimonial-card__role">Creative Director, B-SIDE</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA ───────────────────────────────────────────────── -->
  <section class="cta">
    <div class="cta__bg brutalist-grid"></div>
    <div class="cta__content">
      <h2 class="cta__title">READY TO<br />BUILD?</h2>
      <p class="cta__text">
        We take on a limited number of projects each quarter to ensure
        architectural excellence. Secure your slot in the studio today.
      </p>
      <div class="cta__actions">
        <button class="cta__btn cta__btn--primary">INITIATE PROJECT</button>
        <button class="cta__btn cta__btn--secondary">SEND AN EMAIL</button>
      </div>
    </div>
  </section>

  <!-- ── FAB ───────────────────────────────────────────────── -->
  <div class="fab">
    <button class="fab__button" aria-label="Open chat">
      <span class="material-symbols-outlined fab__icon">chat_bubble</span>
    </button>
  </div>
</Layout>
