---
import Layout from '../../layouts/Layout.astro';
import '../../styles/hero.css';
---

<Layout title="Website Audit | AFM.DEV" description="Technical SEO, Core Web Vitals and UX insights to boost your site's growth.">
  <section class="hero hero--grid" aria-label="Website Audit">
    <h1 class="hero__title">
      WEBSITE<br /><span class="hero__title-highlight">AUDIT</span>
    </h1>
    <p class="hero__subtitle">Technical SEO · Core Web Vitals · UX Insights</p>
    <div class="hero__actions">
      <a href="/contact" class="hero__btn hero__btn--primary">START A PROJECT</a>
      <a href="/services" class="hero__btn hero__btn--secondary">ALL SERVICES</a>
    </div>

    <div class="hero__image" aria-hidden="true">
      <div class="hero__image-inner">
        <img
          alt="Data analysis and website audit dashboard"
          src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&h=600&fit=crop&q=80"
          width="800"
          height="600"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>

  </section>
</Layout>
