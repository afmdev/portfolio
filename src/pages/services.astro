---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import '../styles/pages/index.css';
import '../styles/pages/services.css';
import { SERVICES as services, SERVICES_HEADING, SERVICES_SUBTITLE } from '../constants/services';

const allPosts = await getCollection('blog');
const posts = allPosts
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 6);

const testimonials = [
  {
    variant: 1 as const,
    quote: 'AFM.DEV didn\'t just build a website; they built a fortress for my brand. The aesthetic is raw, powerful, and unique.',
    name: 'MARCUS VOGEL',
    role: 'Founder, Neo Gallery',
    avatarSrc: 'https://lh3.googleusercontent.com/aida-public/AB6AXuBbUGmzhXtYcE_csR_E64WOd3rkWcxZAsvg2IuOXy9OH9C138msAvGzoaCr0lnm_aHxoLRjjFmHvGrWNGSsgVAn2uqAewEYA-ePcX7_MvZM8jM0I8RYqw9wujmV4BXba1VdhGZGAxgKFNoUPmLAq9hknWeuivGhY3I-sx7Kht6HrIz1vPO8tw3XeR5J5sDi6pohb-Xzvke9eYncAtBFMWVA6VyZm5UvJKE0tujw3ewFBPzBQRs-fL2r5Yj5OikiO1x6hR7ICHHzFZpP',
    avatarAlt: 'Marcus Vogel',
  },
  {
    variant: 2 as const,
    quote: 'The level of digital precision is unmatched. Our conversion rates tripled because the design commands respect immediately.',
    name: 'ELENA ROSSI',
    role: 'Tech Lead, Flow-State',
    avatarSrc: 'https://lh3.googleusercontent.com/aida-public/AB6AXuDpHhTs2YXrZuMryPxJNEyekNq_j4B_3gKQ0s6c9vvNc-bhKcHCYG7k8XN8zNsblRXVKuaqWGLANWjDCxPLswvsBGJd4HErlmpMuwd8Yo215SMy3O0OFAXIdyT2_0s8-NlCcnJWUHGgtn0DtSDysNnK9E7bTJss2gmJ9wPh5ImOa7WppD7pz_IZNPPIVV37QnNEhqUUZc2FvUbeyg-Yn--zZGBOA5JsSWzuJ-R88i10hYHiYktKUpaC4TdSd8A4RMSqLtY7ljTtHVzu',
    avatarAlt: 'Elena Rossi',
  },
  {
    variant: 3 as const,
    quote: 'Berlin brutalism at its finest. If you want to stand out from the sea of soft-rounded SaaS designs, this is the place.',
    name: 'JAKOB SCHMIDT',
    role: 'Creative Director, B-SIDE',
    avatarSrc: 'https://lh3.googleusercontent.com/aida-public/AB6AXuB219GJAnEjcC3lCqolYEbI6YiPAVNtOAe7oKf30Xofy3KrJy-pQBAQZo09FypuT2TE5xQI1dci1Jcw_973UzdvC37Cgs9EgvxJLem3mQmJ2-09sunWaJgLCWQddQYfQ4itHfiREy2-AxJI4lgsh8uEKKgPYPMkjRK1WJdL0Zv7R5tXav-INd4bGRu55JTwmoq_h8N90ILfPMZGDUYzfeSNalcLLHezTPvZFvmypH9cYcgvmCXIBQd6-odrZSjuP1nDLILRLeCx2Ubw',
    avatarAlt: 'Jakob Schmidt',
  },
];

const badgeVariants: ('purple' | 'mint')[] = ['purple', 'mint', 'purple', 'mint', 'purple', 'mint'];
---

<Layout
  title="AFM.DEV | WEBDESIGN IN BERLIN"
  description="Freelance Design & Development for Modern Creators. Berlin-based web design studio."
>
  <!-- ── Hero ──────────────────────────────────────────────── -->
  <section class="hero brutalist-grid" aria-label="Hero">
    <div class="hero__content">
      <!-- <span class="hero__eyebrow">FREELANCE STUDIO · BERLIN</span> -->
      <h1 class="hero__title">DIGITAL SERVICES<br />THAT SCALE</h1>
      <p class="hero__subtitle">
        Web Development, UX Design & SEO Optimization in Berlin
      </p>
      <div class="hero__actions">
        <a href="/contact" class="hero__btn hero__btn--primary">START A PROJECT</a>
        <a href="/contact" class="hero__btn hero__btn--secondary">HOW WE WORK</a>
      </div>
    </div>
    <div class="hero__image" aria-hidden="true">
      <div class="hero__image-inner">
        <img
          alt="Brutalist concrete building in Berlin with sharp geometric shadows"
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuDAh_47G1TJFASTBGt9VRP2AJHBXxF7G0iAz0egJy_jlkvxG2s7zTkenxqJ4Lvky8ELHVNWfl1XndhsrJREj5FEXKTWB01cX6thUVq7tl_xBUz6iA3tR3wbrQTvvY-ZG2fqIE57YcItV8aJmgEtAbjl1Z75eqZ43Qb3gL_StMNGB78ZSA8ltp5lJNa6JKXvf-9NlKZzN6uxTJJh5DfrB6OachjnCIJeEws2CnhNnoF8Nk8fZMUreOOeqXFbgjrCkBOr_CAr9kFY18e_"
          width="800"
          height="600"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  <!-- ── Marquee ───────────────────────────────────────────── -->
  <section class="marquee-section" aria-hidden="true">
    <div class="marquee-section__container">
      <div class="marquee-section__track">
        <span class="marquee-section__word">STRATEGY</span>
        <span class="marquee-section__divider"></span>
        <span class="marquee-section__word">DEVELOPMENT</span>
        <span class="marquee-section__divider"></span>
        <span class="marquee-section__word">SEO</span>
        <span class="marquee-section__divider"></span>
        <span class="marquee-section__word">DESIGN</span>
        <span class="marquee-section__divider"></span>
        <!-- Duplicate for seamless loop -->
        <span class="marquee-section__word">STRATEGY</span>
        <span class="marquee-section__divider"></span>
        <span class="marquee-section__word">DEVELOPMENT</span>
        <span class="marquee-section__divider"></span>
        <span class="marquee-section__word">SEO</span>
        <span class="marquee-section__divider"></span>
        <span class="marquee-section__word">DESIGN</span>
        <span class="marquee-section__divider"></span>
      </div>
    </div>
  </section>

  <!-- ── Services ─────────────────────────────────────────────── -->
  <section class="services" aria-labelledby="services-heading">
    <div class="services__heading-area">
      <h2 id="services-heading" class="services__title" set:html={SERVICES_HEADING.replace(/\n/g, '<br/>')}></h2>
      <p class="services__subtitle">{SERVICES_SUBTITLE}</p>
    </div>

    <div class="services__grid">
      {services.slice(0, 6).map((s) => (
        <ServiceCard
          color={s.color}
          icon={s.icon}
          title={s.title}
          tagline={s.tagline}
          desc={s.desc}
          href={s.href}
          cta={s.cta}
        />
      ))}
    </div>

    <div class="services__cta">
      <div class="services__cta-content">
        <h3 class="services__cta-title">READY TO START BUILDING?</h3>
        <p class="services__cta-text">Every project begins with a blueprint. Let's discuss your architectural vision and bring it to life with precision.</p>
      </div>
      <a href="/contact" class="services__cta-btn">WE ARE READY</a>
    </div>
  </section>

  <!-- ── Testimonials ──────────────────────────────────────── -->
  <section class="testimonials" aria-labelledby="testimonials-heading">
    <h2 id="testimonials-heading" class="testimonials__title">VOICES OF THE CURATED</h2>

    <div class="testimonials__grid">
      {testimonials.map((t) => (
        <TestimonialCard
          variant={t.variant}
          quote={t.quote}
          name={t.name}
          role={t.role}
          avatarSrc={t.avatarSrc}
          avatarAlt={t.avatarAlt}
        />
      ))}
    </div>
  </section>

  <!-- ── CTA ───────────────────────────────────────────────── -->
  <section class="cta" aria-labelledby="cta-heading">
    <div class="cta__bg brutalist-grid" aria-hidden="true"></div>
    <div class="cta__content">
      <h2 id="cta-heading" class="cta__title">READY TO<br />BUILD?</h2>
      <p class="cta__text">
        We take on a limited number of projects each quarter to ensure
        architectural excellence. Secure your slot in the studio today.
      </p>
      <div class="cta__actions">
        <a href="/contact" class="cta__btn cta__btn--primary">INITIATE PROJECT</a>
        <a href="mailto:hello@afm.dev" class="cta__btn cta__btn--secondary">SEND AN EMAIL</a>
      </div>
    </div>
  </section>

  <!-- ── FAB ───────────────────────────────────────────────── -->
  <div class="fab">
    <button class="fab__button" type="button" aria-label="Open chat">
      <svg class="fab__icon" width="30" height="30" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M4 5C4 3.9 4.9 3 6 3H24C25.1 3 26 3.9 26 5V19C26 20.1 25.1 21 24 21H17L11 27V21H6C4.9 21 4 20.1 4 19V5Z" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/>
        <circle cx="10" cy="12" r="1.5" fill="currentColor"/>
        <circle cx="15" cy="12" r="1.5" fill="currentColor"/>
        <circle cx="20" cy="12" r="1.5" fill="currentColor"/>
      </svg>
    </button>
  </div>
</Layout>
